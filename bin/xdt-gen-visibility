#!/bin/bash
# Minimal xdt-gen-visibility replacement for XFCE builds
# With default visibility, no explicit symbol exports needed

kind=""
input=""
output=""
args=()
while [[ $# -gt 0 ]]; do
    case "$1" in
        --kind=*)
            kind="${1#--kind=}"; shift;;
        --kind)
            kind="$2"; shift 2;;
        --mode)
            shift 2;;
        *)
            args+=("$1"); shift;;
    esac
done

input="${args[0]:-}"
output="${args[1]:-}"

libname=$(basename "$input" .symbols | tr '[:lower:]' '[:upper:]')
libname_lower=$(basename "$input" .symbols)

if [[ "$kind" == "header" ]]; then
    cat > "$output" << HEADER
/* Generated by xdt-gen-visibility */
#ifndef __${libname}_VISIBILITY_H__
#define __${libname}_VISIBILITY_H__

#define ${libname}_EXPORT __attribute__((visibility("default")))
#define ${libname}_INTERNAL
#define ${libname}_HIDDEN __attribute__((visibility("hidden")))

#ifdef ${libname}_COMPILATION
  #define ${libname}_API ${libname}_EXPORT
#else
  #define ${libname}_API
#endif

#define ${libname}_DEPRECATED __attribute__((deprecated))
#define ${libname}_DEPRECATED_FOR(f) __attribute__((deprecated("Use " #f " instead")))

#endif /* __${libname}_VISIBILITY_H__ */
HEADER

elif [[ "$kind" == "source" ]]; then
    # Empty source - default visibility handles symbol export
    cat > "$output" << 'SRC'
/* Generated by xdt-gen-visibility */
/* Default visibility mode - no explicit exports needed */
SRC
fi

exit 0
